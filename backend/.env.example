# Backend Environment Variables - Copy to .env and fill values

PORT=3000
MONGO_URI=mongodb://localhost:27017/assurance_leads
# Or MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/assurance_leads

JWT_SECRET=your_super_secret_jwt_key_here_change_this
ADMIN_EMAIL=admin@courtier.fr
ADMIN_PASSWORD=change_me_secure_password

OPENAI_API_KEY=sk-your_openai_api_key_here

N8N_WEBHOOK_BASE_URL=http://your-n8n-instance/webhook/
# Example: http://localhost:5678/webhook/relance-nouveau

NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

